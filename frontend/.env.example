# Frontend Environment Variables
# Copy this file to .env.local for local development
# For production deployment, set these variables in your hosting platform (Vercel, Netlify, etc.)

# ============================================
# API Configuration (REQUIRED)
# ============================================

# Local development (default)
VITE_API_URL=https://ayupulseapp.onrender.com

# Production examples (uncomment and update as needed):
# VITE_API_URL=https://ayupulse-backend.up.railway.app
# VITE_API_URL=https://ayupulseapp.onrender.com
# VITE_API_URL=https://api.ayupulse.com
# VITE_API_URL=https://your-backend-domain.com

# ============================================
# Application Configuration
# ============================================

VITE_APP_NAME=AyuPulse
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=AI-Powered Ayurvedic Health Prediction Platform

# ============================================
# Authentication & Security
# ============================================

# JWT token refresh interval (in minutes)
VITE_TOKEN_REFRESH_INTERVAL=25

# Session timeout warning (in minutes)
VITE_SESSION_TIMEOUT_WARNING=5

# ============================================
# Feature Flags
# ============================================

# Enable/disable specific features
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_LOGS=false
VITE_ENABLE_PREDICTION_HISTORY=true
VITE_ENABLE_PATIENT_MANAGEMENT=true

# ============================================
# UI/UX Configuration
# ============================================

# Theme configuration
VITE_DEFAULT_THEME=light  # light, dark, system
VITE_ENABLE_THEME_TOGGLE=true

# Dashboard configuration
VITE_DASHBOARD_REFRESH_INTERVAL=30  # seconds
VITE_MAX_PREDICTIONS_PER_PAGE=10

# ============================================
# External Services (Optional)
# ============================================

# Google Analytics (if enabled)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry Error Tracking (if enabled)
# VITE_SENTRY_DSN=https://xxxxxxxxxxxxx.ingest.sentry.io/xxxxxxx

# ============================================
# Development & Debugging
# ============================================

# Enable mock API for development
VITE_USE_MOCK_API=false

# Log level: debug, info, warn, error
VITE_LOG_LEVEL=info

# ============================================
# Production Deployment Notes
# ============================================

# For Vercel deployment:
# 1. Go to Project Settings → Environment Variables
# 2. Add all required variables (VITE_API_URL is mandatory)
# 3. For Railway backend, use: VITE_API_URL=https://your-backend.up.railway.app
# 4. Make sure CORS is configured in backend to allow your Vercel domain

# For Railway deployment (if deploying frontend on Railway):
# 1. Set VITE_API_URL to your backend URL
# 2. Add all environment variables in Railway dashboard
# 3. Build command: npm run build
# 4. Output directory: dist

# ============================================
# Troubleshooting
# ============================================

# If you see "Network Error" after deployment:
# 1. Check VITE_API_URL is correct and accessible
# 2. Verify backend CORS settings include your frontend domain
# 3. Test backend API directly: curl https://your-backend-url.com/health
# 4. Check browser console for specific error messages

# If environment variables aren't loading:
# 1. Variables must start with VITE_ to be exposed to client code
# 2. Rebuild the application after changing variables
# 3. Clear browser cache and hard reload (Ctrl+Shift+R)