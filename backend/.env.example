# AyuPulseApp Backend Environment Variables
# Copy this file to .env for local development
# For production deployment (Railway, Heroku, etc.), set these variables in your hosting platform

# ============================================
# MongoDB Configuration (REQUIRED)
# ============================================

# Local development (default)
MONGODB_URL=mongodb+srv://ayu-user-app-v2:pankaj092005@cluster0.kd08zo1.mongodb.net/ayupulse?retryWrites=true&w=majority&appName=Cluster0

# Production examples (MongoDB Atlas):
# MONGODB_URL=mongodb+srv://username:password@cluster0.mongodb.net/ayupulse?retryWrites=true&w=majority
# MONGODB_URL=mongodb://username:password@cluster0-shard-00-00.mongodb.net:27017,cluster0-shard-00-01.mongodb.net:27017,cluster0-shard-00-02.mongodb.net:27017/ayupulse?ssl=true&replicaSet=Cluster0-shard-0&authSource=admin&retryWrites=true&w=majority

DATABASE_NAME=ayupulse

# ============================================
# JWT & Authentication Configuration (REQUIRED)
# ============================================

# SECRET_KEY: Generate a strong random key for production
# Use: openssl rand -hex 32  or  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=7xK9mP2vQ8sL1aB5nR4tY6uW0cD3fH9j
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# CORS Configuration (REQUIRED for production)
# ============================================

# Local development
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5174","http://127.0.0.1:5174"]

# Production examples (add your frontend domains):
# BACKEND_CORS_ORIGINS=["https://ayupulse.vercel.app","https://www.ayupulse.com","https://ayupulse.com"]
# For Railway + Vercel deployment:
# BACKEND_CORS_ORIGINS=["https://ayu-pulse-app.vercel.app","https://ayupulseapp.vercel.app","https://ayupulseapp-pankajcseaiml.vercel.app"]

# ============================================
# Application Settings
# ============================================

PROJECT_NAME=AyuPulseApp

# DEBUG: Set to False in production for security
DEBUG=True  # Change to False in production

# ============================================
# File Upload Settings
# ============================================

MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/jpg"]

# Upload directory (relative to backend root)
UPLOAD_DIR=./uploads

# ============================================
# ML Model Paths
# ============================================

# Paths to pre-trained ML models (if using)
XRAY_MODEL_PATH=./ml/models/xray_model.pth
ECG_MODEL_PATH=./ml/models/ecg_model.pth
CLINICAL_MODEL_PATH=./ml/models/clinical_model.pkl

# ============================================
# Optional: Email Configuration
# ============================================

# Uncomment and configure for email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@ayupulse.com
# EMAIL_ENABLED=False

# ============================================
# Optional: Logging Configuration
# ============================================

# LOG_LEVEL: debug, info, warning, error, critical
LOG_LEVEL=info

# LOG_FILE: Path to log file (optional)
# LOG_FILE=./logs/app.log

# ============================================
# Railway-Specific Configuration
# ============================================

# Railway automatically provides PORT environment variable
# PORT=8000  # Railway sets this automatically

# For Railway deployment:
# 1. Set MONGODB_URL to your MongoDB Atlas connection string
# 2. Set SECRET_KEY to a strong random value
# 3. Set DEBUG=False
# 4. Set BACKEND_CORS_ORIGINS to include your Vercel frontend domain
# 5. Add all required variables in Railway dashboard → Environment Variables

# ============================================
# Security Notes for Production
# ============================================

# 1. NEVER commit .env files to version control
# 2. Use different SECRET_KEY for each environment
# 3. Set DEBUG=False in production
# 4. Use HTTPS in production (Railway provides automatically)
# 5. Regularly rotate database credentials and secrets
# 6. Monitor application logs for suspicious activity

# ============================================
# Troubleshooting
# ============================================

# If MongoDB connection fails:
# 1. Check connection string format
# 2. Verify network access (IP whitelist in MongoDB Atlas)
# 3. Check credentials

# If CORS errors occur:
# 1. Verify BACKEND_CORS_ORIGINS includes exact frontend URL
# 2. Check for trailing slashes or protocol mismatches
# 3. Restart backend after changing CORS settings

# If file uploads fail:
# 1. Check MAX_UPLOAD_SIZE is sufficient
# 2. Verify UPLOAD_DIR exists and is writable
# 3. Check ALLOWED_IMAGE_TYPES includes your file type